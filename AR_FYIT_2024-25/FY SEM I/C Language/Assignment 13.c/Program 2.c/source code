#include<stdio.h>
void prime(int);

void prime(int a)
{
    if(a==2)
    {
        printf("a is prime number ");
    }
    else if(a%2==0)
    {
        printf("a is not prime number ");
    }
    else{
        printf("a is prime number ");
    }
};
int main()
{
    int a;
    printf("enter the value of a:");
    scanf("%d", &a);
    
    prime(a);
}