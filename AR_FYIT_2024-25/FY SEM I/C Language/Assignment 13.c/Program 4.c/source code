#include<stdio.h>
void swap(int *a, int *b)
{
    int c;
    c=*a;
    *a=*b;
    *b=c;
    
}
int main()
{
    int num1;
    int num2;
    
    printf("enter the first number :");
    scanf("%d",&num1);
    
    printf("enter the second number:");
    scanf("%d",&num2);
    
    printf("\n before swapping:\n");
    printf("num1=%d , num2=%d\n",num1,num2);
    swap(&num1,&num2);
    printf("after swapping:\n");
    printf("num1=%d , num2=%d\n",num1,num2);
    
}