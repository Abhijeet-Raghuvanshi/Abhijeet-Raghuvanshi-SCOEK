#include <stdio.h>

// Function prototype
void calculateTriangleArea(float base, float height, float *area);

int main() {
    float base, height, area;

    // Input for base and height
    printf("Enter the base of the triangle: ");
    scanf("%f", &base);

    printf("Enter the height of the triangle: ");
    scanf("%f", &height);

    // Call the function by reference
    calculateTriangleArea(base, height, &area);

    // Display the result
    printf("The area of the triangle is: %.2f\n", area);

    return 0;
}

// Function definition
void calculateTriangleArea(float base, float height, float *area) {
    *area = 0.5 * base * height; // Calculate area and store in the variable pointed by 'area'
}