#include <stdio.h>

struct Book {
    int book_id;
    char book_title[100];
    char book_author[50];
    float book_price;
};

int main() {
    const int NUM_BOOKS = 20; 
    struct Book books[NUM_BOOKS]; 

    for (int i = 0; i < NUM_BOOKS; i++) {
        printf("\nEnter details for Book %d:\n", i + 1);
        printf("Enter Book ID: ");
        scanf("%d", &books[i].book_id);

        printf("Enter Book Title: ");
        scanf(" %[^\n]", books[i].book_title); 

        printf("Enter Book Author: ");
        scanf(" %[^\n]", books[i].book_author);

        printf("Enter Book Price: ");
        scanf("%f", &books[i].book_price);
    }

    printf("\nBook Details:\n");
    for (int i = 0; i < NUM_BOOKS; i++) {
        printf("\nBook %d:\n", i + 1);
        printf("ID: %d\n", books[i].book_id);
        printf("Title: %s\n", books[i].book_title);
        printf("Author: %s\n", books[i].book_author);
        printf("Price: %.2f\n", books[i].book_price);
    }

    return 0;
}