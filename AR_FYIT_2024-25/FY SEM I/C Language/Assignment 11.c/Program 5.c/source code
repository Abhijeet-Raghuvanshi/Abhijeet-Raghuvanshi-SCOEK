#include <stdio.h>

// Define the Employee structure
struct Employee {
    int emp_id;
    char emp_name[50];
    char emp_designation[50];
    float emp_sal;
};

int main() {
    const int NUM_EMPLOYEES = 20; 
    struct Employee employees[NUM_EMPLOYEES]; 

    for (int i = 0; i < NUM_EMPLOYEES; i++) {
        printf("\nEnter details for Employee %d:\n", i + 1);
        printf("Enter Employee ID: ");
        scanf("%d", &employees[i].emp_id);

        printf("Enter Employee Name: ");
        scanf(" %[^\n]", employees[i].emp_name); 

        printf("Enter Employee Designation: ");
        scanf(" %[^\n]", employees[i].emp_designation);

        printf("Enter Employee Salary: ");
        scanf("%f", &employees[i].emp_sal);
    }

    printf("\nEmployee Details:\n");
    for (int i = 0; i < NUM_EMPLOYEES; i++) {
        printf("\nEmployee %d:\n", i + 1);
        printf("ID: %d\n", employees[i].emp_id);
        printf("Name: %s\n", employees[i].emp_name);
        printf("Designation: %s\n", employees[i].emp_designation);
        printf("Salary: %.2f\n", employees[i].emp_sal);
    }

    return 0;
}