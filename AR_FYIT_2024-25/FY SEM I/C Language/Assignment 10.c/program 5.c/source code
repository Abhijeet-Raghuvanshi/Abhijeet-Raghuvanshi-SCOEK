#include <stdio.h>

int main() {
    int arr[5], *ptr;

    // Input array elements
    printf("Enter 5 elements of the array:\n");
    for (int i = 0; i < 5; i++) {
        scanf("%d", &arr[i]);
    }

    // Assign the address of the first element of the array to the pointer
    ptr = arr;

    // Display array elements using the pointer
    printf("Array elements are:\n");
    for (int i = 0; i < 5; i++) {
        printf("%d ", *(ptr + i)); // Access elements using pointer arithmetic
    }

    printf("\n");

}