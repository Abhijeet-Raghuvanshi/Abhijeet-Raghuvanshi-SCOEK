#include <stdio.h>

int main() {
    int arr[5], *ptr, sum = 0;

    // Input array elements
    printf("Enter 5 elements of the array:\n");
    for (int i = 0; i < 5; i++) {
        scanf("%d", &arr[i]);
    }

    // Assign the address of the first element of the array to the pointer
    ptr = arr;

    // Calculate the sum of array elements using the pointer
    for (int i = 0; i < 5; i++) {
        sum += *(ptr + i); // Access elements using pointer arithmetic
    }

    // Display the sum
    printf("The sum of array elements is: %d\n", sum);

}