#include <stdio.h>

int main() {
    float num1, num2, sum;
    float *ptr1, *ptr2; // Pointers to hold the addresses of num1 and num2

    // Input two float numbers
    printf("Enter the first number: ");
    scanf("%f", &num1);
    printf("Enter the second number: ");
    scanf("%f", &num2);

    // Assign the addresses of num1 and num2 to the pointers
    ptr1 = &num1;
    ptr2 = &num2;

    // Perform addition using pointers
    sum = *ptr1 + *ptr2;

    // Display the result
    printf("The sum of %.2f and %.2f is: %.2f\n", *ptr1, *ptr2, sum);

   
}